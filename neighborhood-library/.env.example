# ── Backend ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://library_user:library_password@db:5432/library
TEST_DATABASE_URL=postgresql+psycopg2://library_user:library_password@db:5432/library_test
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Fine calculation: USD charged per overdue day
FINE_RATE_PER_DAY=0.50

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000

# ── Frontend ──────────────────────────────────────────────────────────────────
# Public URL of the backend (browser-visible)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Internal URL of the backend (used by Next.js server-side / rewrites)
BACKEND_INTERNAL_URL=http://backend:8000
